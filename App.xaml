<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiskostenApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Common styles (controls, fonts, sizes) -->
                <ResourceDictionary Source="Resources/Styles.Common.xaml" />

                <!-- Default theme: load Light by default; SettingsPage will swap to Dark when requested -->
                <ResourceDictionary Source="Resources/Styles.Light.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
