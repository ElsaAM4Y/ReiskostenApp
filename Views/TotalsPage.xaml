<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiskostenApp.Views.TotalsPage"
             Title="Totals"
             BackgroundColor="{DynamicResource BackgroundColor}">
    <StackLayout Padding="12">
        <CollectionView x:Name="TotalsCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Year}" />
                        <Label Grid.Column="1" Text="{Binding TotalAmount, StringFormat='{}{0:C}'}" HorizontalOptions="End" />
                        <Label Grid.Row="1" Text="{Binding Month}" FontSize="Micro" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding TotalDays, StringFormat='Days: {0}'}" HorizontalOptions="End" FontSize="Micro" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>
