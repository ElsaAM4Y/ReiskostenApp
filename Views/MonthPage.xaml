<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ReiskostenApp.Views.MonthPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ReiskostenApp.ViewModels"
    BackgroundColor="{DynamicResource PageBackgroundColor}">

    <VerticalStackLayout Padding="16" Spacing="12">

        <!-- Titel -->
        <Label 
            Text="{Binding Title}"
            FontSize="22"
            FontAttributes="Bold"
            TextColor="{DynamicResource TextColor}" />

        <!-- Dagenlijst -->
        <CollectionView ItemsSource="{Binding Days}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="100,60,*" Padding="0,6">

                        <!-- Datum -->
                        <Label 
                            Text="{Binding Date, StringFormat='{0:dd MMM}'}"
                            TextColor="{DynamicResource TextColor}"
                            VerticalOptions="Center" />

                        <!-- Getal -->
                        <Entry
                            Grid.Column="1"
                            Style="{StaticResource EntryStyle}"
                            Keyboard="Numeric"
                            Text="{Binding Value, Mode=TwoWay}"
                            TextChanged="Entry_TextChanged" />

                        <!-- Aantekeningen -->
                        <Editor
                            Grid.Column="2"
                            Style="{StaticResource EditorStyle}"
                            Text="{Binding Notes, Mode=TwoWay}"
                            AutoSize="TextChanges"
                            Placeholder="Aantekening…" />

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Totaal -->
        <Label
            Text="{Binding Total, StringFormat='Totaal: {0}'}"
            FontSize="18"
            FontAttributes="Bold"
            TextColor="{DynamicResource TextColor}"
            HorizontalOptions="End" />

    </VerticalStackLayout>
</ContentPage>
