<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiskostenApp.Views.MonthPage"
             Title="Month"
             BackgroundColor="{DynamicResource BackgroundColor}">
    <ScrollView>
    <StackLayout Padding="12" Spacing="10">
        <StackLayout Orientation="Horizontal" Spacing="8">
            <Picker x:Name="MonthPicker" WidthRequest="180" />
            <Picker x:Name="YearPicker" WidthRequest="120" />
            <Button Text="Save" Clicked="OnSaveClicked" />
        </StackLayout>

        <CollectionView x:Name="DaysCollection" ItemsSource="{Binding Days}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="6" ColumnDefinitions="40,*,80">
                        <Label Text="{Binding Day}" VerticalOptions="Center" TextColor="{DynamicResource TextColor}" />
                        <Entry Grid.Column="1" Text="{Binding Notes, Mode=TwoWay}" BackgroundColor="{DynamicResource EntryBackgroundColor}" />
                        <StackLayout Grid.Column="2" Orientation="Vertical">
                            <Stepper Minimum="0" Maximum="2" Increment="1" Value="{Binding Value, Mode=TwoWay}" />
                            <Label Text="{Binding Amount, StringFormat='{}{0:C}'}" HorizontalOptions="End" TextColor="{DynamicResource TextColor}" />
                        </StackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label x:Name="MonthTotalLabel" Text="Totals" TextColor="{DynamicResource TextColor}" HorizontalOptions="Center" />
    </StackLayout>
    </ScrollView>
</ContentPage>
