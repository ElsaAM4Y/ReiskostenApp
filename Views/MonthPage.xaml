<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiskostenApp.Views.MonthPage"
             Title="Month"
             BackgroundColor="{DynamicResource BackgroundColor}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="LabelPrimary" TargetType="Label">
                <Setter Property="TextColor" Value="{DynamicResource TextColor}" />
                <Setter Property="FontSize" Value="16" />
            </Style>
            <Style x:Key="EntryStyle" TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{DynamicResource EntryBackgroundColor}" />
                <Setter Property="TextColor" Value="{DynamicResource TextColor}" />
            </Style>
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
                <Setter Property="TextColor" Value="White" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout Padding="12" Spacing="8">
        <Grid ColumnDefinitions="*,*,Auto" RowSpacing="8">
            <Picker x:Name="MonthPicker" Grid.Column="0" Title="Month" />
            <Picker x:Name="YearPicker" Grid.Column="1" Title="Year" />
            <Button Text="Save" Grid.Column="2" Style="{StaticResource PrimaryButton}" Clicked="OnSaveClicked"/>
        </Grid>

        <CollectionView x:Name="DaysCollection" Margin="0,12,0,0" ItemsLayout="VerticalList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="6" ColumnDefinitions="40,*,200">
                        <Label Text="{Binding Day}" VerticalOptions="Center" Style="{StaticResource LabelPrimary}" />
                        <Entry Text="{Binding Value, Mode=TwoWay}" Keyboard="Numeric" Style="{StaticResource EntryStyle}" />
                        <Entry Text="{Binding Notes, Mode=TwoWay}" Placeholder="Notes" Style="{StaticResource EntryStyle}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label x:Name="MonthTotalLabel" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,12,0,0" Style="{StaticResource LabelPrimary}" />
    </VerticalStackLayout>
</ContentPage>
