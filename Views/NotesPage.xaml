<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiskostenApp.Views.NotesPage"
             Title="Aantekeningen"
             BackgroundColor="{DynamicResource PageBackgroundColor}">
    <ScrollView>
    <StackLayout Padding="12" Spacing="8">
        <StackLayout Padding="6">
            <Entry x:Name="NoteTitle" Placeholder="Titel" MinimumHeightRequest="48" BackgroundColor="{DynamicResource EntryBackgroundColor}" TextColor="{DynamicResource PrimaryTextColor}" />
            <Editor x:Name="NoteContent" HeightRequest="120" MinimumHeightRequest="48" BackgroundColor="{DynamicResource EntryBackgroundColor}" TextColor="{DynamicResource PrimaryTextColor}" />
            <StackLayout Orientation="Horizontal" Spacing="8">
                <Button Text="Nieuw" Clicked="OnAddClicked" MinimumHeightRequest="48" />
                <Button Text="Opslaan" Clicked="OnSaveClicked" MinimumHeightRequest="48" />
                <Button Text="Verwijderen" Clicked="OnDeleteClicked" MinimumHeightRequest="48" />
            </StackLayout>
        </StackLayout>

        <CollectionView x:Name="NotesCollection" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" RowDefinitions="Auto,Auto">
                        <Label Text="{Binding Title}" FontSize="18" TextColor="{DynamicResource PrimaryTextColor}" />
                        <Label Grid.Row="1" Text="{Binding Updated, StringFormat='Bijgewerkt: {0:G}'}" FontSize="Micro" TextColor="{DynamicResource SecondaryTextColor}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
    </ScrollView>
</ContentPage>
