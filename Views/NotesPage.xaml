<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiskostenApp.Views.NotesPage"
             Title="Notes"
             BackgroundColor="{DynamicResource BackgroundColor}">
    <StackLayout Padding="12" Spacing="8">
        <Button Text="Add Note" Clicked="OnAddClicked" />
        <CollectionView x:Name="NotesCollection" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8">
                        <Label Text="{Binding Title}" TextColor="{DynamicResource TextColor}" />
                        <Label Grid.Row="1" Text="{Binding Updated, StringFormat='Updated: {0:G}'}" FontSize="Micro" TextColor="{DynamicResource TextColor}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <StackLayout Padding="6">
            <Entry x:Name="NoteTitle" Placeholder="Title" BackgroundColor="{DynamicResource EntryBackgroundColor}" />
            <Editor x:Name="NoteContent" HeightRequest="120" BackgroundColor="{DynamicResource EntryBackgroundColor}" />
            <StackLayout Orientation="Horizontal" Spacing="8">
                <Button Text="Save" Clicked="OnSaveClicked" />
                <Button Text="Delete" Clicked="OnDeleteClicked" />
            </StackLayout>
        </StackLayout>
    </StackLayout>
</ContentPage>
