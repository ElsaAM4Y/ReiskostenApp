<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ReiskostenApp.Views.SettingsPage"
    BackgroundColor="{DynamicResource BackgroundColor}"
    Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Theme" 
             FontAttributes="Bold"
             TextColor="{DynamicResource TextColor}" />

            <Picker x:Name="ThemePicker"
              Title="Select theme"
              TextColor="{DynamicResource TextColor}" />

            <Label Text="Rate per day" 
             FontAttributes="Bold"
             TextColor="{DynamicResource TextColor}" />

            <Entry x:Name="RateEntry"
             Keyboard="Numeric"
             Placeholder="0.00"
             BackgroundColor="{DynamicResource EntryBackgroundColor}"
             TextColor="{DynamicResource TextColor}" />

            <Label Text="Month" 
             FontAttributes="Bold"
             TextColor="{DynamicResource TextColor}" />

            <Picker x:Name="MonthPicker"
              Title="Select month"
              TextColor="{DynamicResource TextColor}" />

            <Label Text="Year" 
             FontAttributes="Bold"
             TextColor="{DynamicResource TextColor}" />

            <Picker x:Name="YearPicker"
              Title="Select year"
              TextColor="{DynamicResource TextColor}" />

            <Button Text="Save"
              Clicked="OnSaveClicked"
              BackgroundColor="{DynamicResource PrimaryColor}"
              TextColor="{DynamicResource TextColor}"
              CornerRadius="6"
              HeightRequest="44" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
