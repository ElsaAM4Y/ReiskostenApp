<?xml version="1.0"  encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiskostenApp.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="{DynamicResource BackgroundColor}">
    <StackLayout Padding="12" Spacing="8">
        <Label Text="Theme" TextColor="{DynamicResource TextColor}" />
        <Picker x:Name="ThemePicker" />
        <Label Text="Rate per day" TextColor="{DynamicResource TextColor}" />
        <Entry x:Name="RateEntry" Keyboard="Numeric" />
        <Label Text="Default Month" TextColor="{DynamicResource TextColor}" />
        <Picker x:Name="MonthPicker" />
        <Label Text="Default Year" TextColor="{DynamicResource TextColor}" />
        <Picker x:Name="YearPicker" />
        <Button Text="Save" Clicked="OnSaveClicked" />
    </StackLayout>
</ContentPage>
