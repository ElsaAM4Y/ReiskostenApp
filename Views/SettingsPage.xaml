<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ReiskostenApp.Views.SettingsPage"
    BackgroundColor="{DynamicResource PageBackgroundColor}"
    Title="Instellingen">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Theme"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <Picker x:Name="ThemePicker"
                    Title="Select theme"
                    ItemsSource="{Binding Themes}"
                    SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                    TextColor="{DynamicResource PrimaryTextColor}" />

            <Label Text="Rate per day"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <Entry x:Name="RateEntry"
                   Keyboard="Numeric"
                   Placeholder="0.00"
                   Text="{Binding RatePerDay, Mode=TwoWay}"
                   BackgroundColor="{DynamicResource EntryBackgroundColor}"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <Label Text="Month"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <Picker x:Name="MonthPicker"
                    Title="Select month"
                    ItemsSource="{Binding MonthNames}"
                    SelectedIndex="{Binding SelectedMonthIndex, Mode=TwoWay}"
                    TextColor="{DynamicResource PrimaryTextColor}" />

            <Label Text="Year"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <Picker x:Name="YearPicker"
                    Title="Select year"
                    ItemsSource="{Binding Years}"
                    SelectedItem="{Binding SelectedYear, Mode=TwoWay}"
                    TextColor="{DynamicResource PrimaryTextColor}" />

            <Button Text="Save"
                    Clicked="OnSaveClicked"
                    BackgroundColor="{DynamicResource ButtonBackgroundColor}"
                    TextColor="{DynamicResource ButtonTextColor}"
                    CornerRadius="6"
                    HeightRequest="44" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
