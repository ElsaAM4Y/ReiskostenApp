<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiskostenApp.Resources.Styles.LightTheme">

    <Color x:Key="PrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextColor">#000000</Color>
    <Color x:Key="PageBackgroundColor">#FFFFFF</Color>
    <Color x:Key="EntryBackgroundColor">#F3F3F3</Color>
    <Color x:Key="AccentColor">#512BD4</Color>
    <Color x:Key="PlaceholderColor">#7A7A7A</Color>

    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryColor}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextColor}" />
    </Style>

    <Color x:Key="SwitchOnColor">#0078D4</Color>
    <Color x:Key="SwitchThumbColor">#FFFFFF</Color>





</ResourceDictionary>