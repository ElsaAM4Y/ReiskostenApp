<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    x:Class="ReiskostenApp.Resources.Styles.Styles"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Activity Indicator -->
    <Style TargetType="ActivityIndicator" x:Key="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource PrimaryTextColor}" />
    </Style>

    <!-- IndicatorView -->
    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{DynamicResource SecondaryTextColor}" />
        <Setter Property="SelectedIndicatorColor" Value="{DynamicResource PrimaryTextColor}" />
    </Style>

    <!-- Border -->
    <Style TargetType="Border" x:Key="Border">
        <Setter Property="Stroke" Value="{DynamicResource SecondaryTextColor}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 15" />
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <!-- MainBorderStyle -->
    <Style x:Key="MainBorderStyle" TargetType="Border">
        <Setter Property="Stroke" Value="{DynamicResource BorderColor}" />
        <Setter Property="StrokeThickness" Value="3" />
        <Setter Property="StrokeShape" Value="RoundRectangle 15" />
        <Setter Property="Margin" Value="10" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <!-- BoxView -->
    <Style TargetType="BoxView" x:Key="BoxView">
        <Setter Property="BackgroundColor" Value="{DynamicResource CardBackgroundColor}" />
    </Style>

    <!-- Button -->
    <Style TargetType="Button" x:Key="Button">
        <Setter Property="TextColor" Value="{DynamicResource ButtonTextColor}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource ButtonBackgroundColor}" />
        <Setter Property="FontFamily" Value="RobotoRegular"/>
        <Setter Property="FontSize" Value="Medium"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest" Value="160"/>
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="WidthRequest" Value="260"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black"
                    Opacity="0.08"
                    Radius="6"
                    Offset="0,2" />
            </Setter.Value>
        </Setter>
    </Style>
    <!-- End Button -->

    <!-- ButtonSelected -->
    <Style TargetType="Button" x:Key="ButtonSelected" BasedOn="{StaticResource Button}">
        <Setter Property="BackgroundColor" Value="{DynamicResource AccentColor}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BorderColor" Value="{DynamicResource AccentColor}" />
        <Setter Property="BorderWidth" Value="3" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black"
                    Opacity="0.35"
                    Radius="14"
                    Offset="0,5" />
            </Setter.Value>
        </Setter>
    </Style>
    <!-- end buttonselected -->

    <Style x:Key="ButtonRound" TargetType="Button">
        <Setter Property="WidthRequest" Value="60" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="TextColor" Value="{DynamicResource ButtonTextColor}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource ButtonBackgroundColor}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>


    <!-- CheckBox -->
    <Style TargetType="CheckBox" x:Key="CheckBox">
        <Setter Property="Color" Value="{DynamicResource PrimaryTextColor}" />
    </Style>

    <!-- DatePicker -->
    <Style TargetType="DatePicker" x:Key="DatePicker">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="Background" Value="{DynamicResource EntryBackgroundColor}" />
        <Setter Property="FontFamily" Value="RobotoRegular"/>
        <Setter Property="FontSize" Value="Medium"/>
    </Style>

    <!-- Editor -->
    <Style TargetType="Editor" x:Key="Editor">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="RobotoRegular"/>
        <Setter Property="FontSize" Value="Medium" />
    </Style>

    <!-- Entry -->
    <Style TargetType="Entry" x:Key="EntryStyle">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource EntryBackgroundColor}" />
        <Setter Property="FontFamily" Value="RobotoRegular"/>
        <Setter Property="FontSize" Value="Medium" />
    </Style>

    <!-- Label -->
    <Style TargetType="Label" x:Key="Label">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="FontFamily" Value="RobotoRegular" />
        <Setter Property="FontSize" Value="Medium" />
    </Style>

    <!-- Label Header -->
    <Style TargetType="Label" x:Key="LabelHeader">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="FontFamily" Value="RobotoBold" />
        <Setter Property="FontSize" Value="Large" />
    </Style>

    <!-- Label H2 -->
    <Style TargetType="Label" x:Key="LabelH2">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="FontFamily" Value="RobotoBold" />
        <Setter Property="FontSize" Value="Medium" />
    </Style>

    <!-- Arrow Label -->
    <Style x:Key="ArrowLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Padding" Value="15" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalOptions" Value="End" />
        <Setter Property="TextColor" Value="{DynamicResource ArrowColor}" />
    </Style>

    <!-- Picker -->
    <Style TargetType="Picker" x:Key="Picker">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="TitleColor" Value="{DynamicResource SecondaryTextColor}" />
        <Setter Property="Background" Value="{DynamicResource EntryBackgroundColor}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource EntryBackgroundColor}" />
        <Setter Property="FontFamily" Value="RobotoRegular"/>
        <Setter Property="FontSize" Value="Medium"/>
    </Style>

    <!-- Slider -->
    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="MaximumTrackColor" Value="{DynamicResource SecondaryTextColor}" />
        <Setter Property="ThumbColor" Value="{DynamicResource PrimaryTextColor}" />
    </Style>

    <!-- Switch -->
    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="ThumbColor" Value="{DynamicResource White}" />
    </Style>

    <!-- TimePicker -->
    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="RobotoRegular"/>
        <Setter Property="FontSize" Value="Medium"/>
    </Style>

    <!-- Page -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{DynamicResource PageBackgroundColor}" />
    </Style>


    <Style TargetType="ActivityIndicator" x:Key="LoadingIndicatorStyle">
        <Setter Property="Color" Value="{DynamicResource LoadingIndicatorColor}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource LoadingIndicatorBackground}" />
        <Setter Property="WidthRequest" Value="40" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>
</ResourceDictionary>