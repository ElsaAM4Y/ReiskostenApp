<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ReiskostenApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ReiskostenApp.Views">

    <ShellContent
        Route="MonthPage"
        Title="Maand"
        ContentTemplate="{DataTemplate views:MonthPage}" />

    <ShellContent
        Route="TotalsPage"
        Title="Totalen"
        ContentTemplate="{DataTemplate views:TotalsPage}" />

    <ShellContent
        Title="Aantekeningen"
        Route="NotesPage"
        ContentTemplate="{DataTemplate views:NotesPage}" />

    <ShellContent
        Title="Instellingen"
        Route="SettingsPage"
        ContentTemplate="{DataTemplate views:SettingsPage}" />

</Shell>
