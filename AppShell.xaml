<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ReiskostenApp.Views"
    x:Class="ReiskostenApp.AppShell"
    FlyoutBehavior="Flyout" >

    <Shell.FlyoutHeader>
            <Label x:Name="FlyoutTitle" Text="Reiskosten" FontAttributes="Bold" FontSize="18" />
    </Shell.FlyoutHeader>
            <!-- Flyout menu items -->
            <FlyoutItem Title="Maand" Icon="calendar.png">
                <ShellContent ContentTemplate="{DataTemplate views:MonthPage}" />
            </FlyoutItem>

            <FlyoutItem Title="Totaal" Icon="totals.png">
                <ShellContent ContentTemplate="{DataTemplate views:TotalsPage}" />
            </FlyoutItem>

            <FlyoutItem Title="Notities" Icon="notes.png">
                <ShellContent ContentTemplate="{DataTemplate views:NotesPage}" />
            </FlyoutItem>

            <FlyoutItem Title="Instellingen" Icon="settings.png">
                <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" />
            </FlyoutItem>

</Shell>
