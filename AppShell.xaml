<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:ReiskostenApp.Views"
       x:Class="ReiskostenApp.AppShell"
       Shell.BackgroundColor="{DynamicResource TabBarBackgroundColor}"
       Shell.TitleColor="{DynamicResource PrimaryTextColor}"
       FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <Grid x:Name="FlyoutHeaderGrid" Padding="16" RowDefinitions="Auto,Auto">
            <Label x:Name="FlyoutTitle" Text="Reiskosten" FontAttributes="Bold" FontSize="18" />

        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Maand" Icon="icon_month.png">
        <ShellContent x:Name="MonthContent" Route="MonthPage" />
    </FlyoutItem>

    <FlyoutItem Title="Totalen" Icon="icon_totals.png">
        <ShellContent x:Name="TotalsContent" Route="TotalsPage" />
    </FlyoutItem>

    <FlyoutItem Title="Aantekeningen" Icon="icon_notes.png">
        <ShellContent x:Name="NotesContent" Route="NotesPage" />
    </FlyoutItem>

    <FlyoutItem Title="Instellingen" Icon="icon_settings.png">
        <ShellContent x:Name="SettingsContent" Route="SettingsPage" />
    </FlyoutItem>

</Shell>
